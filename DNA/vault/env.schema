# ═══════════════════════════════════════════════════════════
# .env.schema - Environment Variable Validation Schema
# Simple validation to catch obvious misconfigurations
# ═══════════════════════════════════════════════════════════

# Required - AI/LLM APIs
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
KIMI_K2_API_KEY=...

# Required - Database
DATABASE_URL=postgresql://...
SUPABASE_URL=https://...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Required - External Services
FIRECRAWL_API_KEY=fc-
N8N_WEBHOOK_URL=https://...
N8N_API_KEY=n8n_api_

# Required - Remote Access
# KIMI_ALLEGRO_API_KEY=sk-kimi-...

# Optional - Development
NODE_ENV=development
DEBUG=true
PYTHON_ENV=development

# Infrastructure - Local LLM
LOCAL_LLM_URL=http://localhost:8080
COMFYUI_URL=http://localhost:8188

# Validation Rules (for tooling):
# - Keys ending in _KEY or _TOKEN should be non-empty
# - URLs should start with http:// or https://
# - DATABASE_URL should start with postgresql:// or postgres://
# - NODE_ENV should be development, production, or test
