# ═══════════════════════════════════════════════════════════
# EVOLUTION STABLES - MASTER API VAULT
# Copy this to /evo/.env and fill in values
# All projects symlink to /evo/.env
# ═══════════════════════════════════════════════════════════

# ─── AI / LLM APIs ─────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
KIMI_K2_API_KEY=...          # For 40GB remote context

# ─── Cloud & Remote ────────────────────────────────────────
# KIMI_ALLEGRO_API_KEY=...           # Allegro access (optional)

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://...
REDIS_URL=redis://...

# ─── External Services ─────────────────────────────────────
FIRECRAWL_API_KEY=...
N8N_WEBHOOK_URL=...

# ─── Development ───────────────────────────────────────────
NODE_ENV=development
PYTHON_ENV=development
DEBUG=true
